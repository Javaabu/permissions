{
    "name": "javaabu/permissions",
    "description": "Modifications brought upon spatie/laravel-permissions",
    "homepage": "https://github.com/Javaabu/permissions",
    "license": "MIT",
    "authors": [
        {
            "name": "Athfan Khaleel",
            "email": "athfan@javaabu.com"
        }
    ],
    "require": {
        "php": "^8.3",
        "illuminate/support": "^12.0 || ^13.0",
        "spatie/laravel-permission": "^7.2",
        "javaabu/helpers": "^1.70",
        "javaabu/activitylog": "^1.5"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "phpunit/phpunit": "^12.5.8 || ^13.0.3"
    },
    "autoload": {
        "psr-4": {
            "Javaabu\\Permissions\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Javaabu\\Permissions\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "2.0-dev"
        },
        "laravel": {
            "providers": [
                "Javaabu\\Permissions\\PermissionsServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
